{
  "manifest_version": 3,
  "name": "EdgeTabGroupsBackup",
  "version": "0.4.9",
  "description": "Back up the current window’s tabs and tab groups into favourites folders (with or without Edge Workspaces).",
  "action": {
    "default_title": "EdgeTabGroupsBackup",
    "default_popup": "src/popup.html"
  },
  "options_page": "src/options.html",
  "permissions": [
    "bookmarks",
    "tabs",
    "tabGroups",
    "storage",
    "windows"
  ],
  "background": {
    "service_worker": "src/background.js",
    "type": "module"
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
